// Begin M-TRAIN TRAIN

// Vehicle

spriteset (spriteset_mtrain_c, ZOOM_LEVEL_IN_4X, BIT_DEPTH_32BPP) {
    template_standard ("1500vemu/mtrain", "m-train-mc")
}
spriteset (spriteset_mtrain_cr, ZOOM_LEVEL_IN_4X, BIT_DEPTH_32BPP) {
    template_reversed_10 ("1500vemu/mtrain", "m-train-mc")
}
spriteset (spriteset_mtrain_t, ZOOM_LEVEL_IN_4X, BIT_DEPTH_32BPP) {
    template_standard ("1500vemu/mtrain", "m-train-t")
}
spriteset (spriteset_mtrain_mp_1, ZOOM_LEVEL_IN_4X, BIT_DEPTH_32BPP) {
    template_reversed_10 ("1500vemu/mtrain", "m-train-mp-2")
}
spriteset (spriteset_mtrain_mp_2, ZOOM_LEVEL_IN_4X, BIT_DEPTH_32BPP) {
    template_standard ("1500vemu/mtrain", "m-train-mp-1")
}


// Purchase Menu
spriteset (spriteset_mtrain_purchase_original, ZOOM_LEVEL_IN_4X, BIT_DEPTH_32BPP) {
    template_purchase ("1500vemu/mtrain", "m-train-mc")
}


switch (FEAT_TRAINS, SELF, switch_mtrain_purchase_original, position_in_consist % 3) {
    1: spriteset_mtrain_purchase_original;
    empty_sprites;
}


switch (FEAT_TRAINS, SELF, switch_mtrain_wagon_unit, (position_in_consist / 3) + 1) {
    2: spriteset_mtrain_mp_1;
    5: spriteset_mtrain_mp_1;
    spriteset_mtrain_t;
}

switch (FEAT_TRAINS, SELF, switch_mtrain_graphics_if_end, (position_in_consist_from_end / 3) + 1) {
    1: spriteset_mtrain_cr;
    2: spriteset_mtrain_mp_2;
    switch_mtrain_wagon_unit;
}

switch (FEAT_TRAINS, SELF, switch_mtrain_middle_wagon_graphics, position_in_consist % 3) {
    1: switch_mtrain_graphics_if_end;
    empty_sprites;
}

switch (FEAT_TRAINS, SELF, switch_mtrain_graphics, position_in_consist % 3) {
    1: spriteset_mtrain_c;
    empty_sprites;
}


//Weight
switch (FEAT_TRAINS, SELF, switch_mtrain_weight_front, (position_in_consist / 3) + 1) {
    2: return 41;
    4..5: return 41;
    return 28;
}

switch (FEAT_TRAINS, SELF, switch_mtrain_weight, (position_in_consist_from_end / 3) + 1) {
    1..2: return 41;
    switch_mtrain_weight_front;
}
//Capacity



switch (FEAT_TRAINS, SELF, switch_mtrain_capacity_1, param_cargo_capacity) {
    4: return 375;
    return (375) / 4 * param_cargo_capacity;
}
switch (FEAT_TRAINS, SELF, switch_mtrain_capacity, position_in_consist % 3) {
    1: switch_mtrain_capacity_1;
    return 0;
}

//Cost



switch (FEAT_TRAINS, SELF, switch_mtrain_running, vehicle_is_potentially_powered) {
    1: return 40;
    return 8;
}

//Power


switch (FEAT_TRAINS, SELF, switch_mtrain_power_front, (position_in_consist / 3) + 1) {
    2: return 708;
    4..5: return 708;
    return 0;
}

switch (FEAT_TRAINS, SELF, switch_mtrain_power, (position_in_consist_from_end / 3) + 1) {
    1..2: return 708;
    switch_mtrain_power_front;
}


switch (FEAT_TRAINS, SELF, switch_mtrain_traction, vehicle_is_potentially_powered) {
    1: return int(0.126*255);
    return 0;
}

// Articulate


switch (FEAT_TRAINS, SELF, switch_mtrain_articulated_part, extra_callback_info1) {
    1..2: return mtrain;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}




item (FEAT_TRAINS, mtrain) {
    property {
        // Menu
        name:                           string(STR_NAME_MTRAIN);
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
        misc_flags:                     bitmask(TRAIN_FLAG_AUTOREFIT, TRAIN_FLAG_MU);
        engine_class:                   ENGINE_CLASS_ELECTRIC;
        variant_group:                  whitehead;

        // Availability
        climates_available:             ALL_CLIMATES;
        introduction_date:              date(1998,12,21);
        model_life:                     40;
        retire_early:                   40;
        vehicle_life:                   45;
        track_type:                     SACd;

        // Cargo
        refittable_cargo_classes:       bitmask(CC_PASSENGERS);
        non_refittable_cargo_classes:   0;
        cargo_allow_refit:              [PASS, TOUR, YETI, YETY];
        cargo_disallow_refit:           [];
        refit_cost:                     0;
        default_cargo_type:             PASS;
        ai_special_flag:                AI_FLAG_PASSENGER;
        cargo_capacity:                 1;
        loading_speed:                  36 << param_loading_speed;
        cargo_age_period:               128 << param_cargo_decay;

        // Stats
        speed:                          80 km/h;
        power:                          528 kW;
        weight:                         40.5 ton;
        tractive_effort_coefficient:    0.126;
        cost_factor:                    40;
        running_cost_base:              RUNNING_COST_ELECTRIC;
        running_cost_factor:            8;
        reliability_decay:              8;
        bitmask_vehicle_info:           bitmask(2);
    }
    graphics {
        // Menu
        additional_text:                string(STR_DESC_7, string(STR_ELECTRIC_1500VDC), string(STR_USEDLINE_URL), string(STR_MTR_NORMAL_CAN_ATTACH_WAGON),string(STR_RELDEC_LOW, 8), string(STR_NORMAL_HEAD_SEAT));
        can_attach_wagon:               muhead_without_first_class;
        start_stop:                     mu4to12car;

        // Graphics
        default:                        switch_mtrain_graphics;
        purchase:                       switch_mtrain_purchase_original;
        articulated_part:               switch_mtrain_articulated_part;

        // Stats
        length:                         switch_length_2_6_2;
/*         speed:                          130; */
/*         power:                          return 0; */
/*         purchase_power:                 return 1218; // HP */
/*         tractive_effort_coefficient:    return 0; */
/*         purchase_tractive_effort_coefficient: return int(0.171*255); */
        cargo_capacity:                 switch_mtrain_capacity;
        cargo_age_period:               128 << param_cargo_decay;
        cost_factor:                    45;
        running_cost_factor:            10  * runningcostfactor() + 20;
        purchase_running_cost_factor:   70;
        purchase_cargo_capacity:        125/3;
        bitmask_vehicle_info:           bitmask(2);
        name:                           switch_whitehead_name;
    }

    // Multiple Unit Wagons
    livery_override(normal_emucoach) {
        default:                        switch_mtrain_middle_wagon_graphics;
        cargo_capacity:                 switch_mtrain_capacity;
        power:                          switch_mtrain_power;
        tractive_effort_coefficient:    switch_mtrain_traction;
        length:                         switch_length_2_6_2;
        weight:                         switch_mtrain_weight;
        can_attach_wagon:               mu_of_mtr;
        cargo_age_period:               128 << param_cargo_decay;
        bitmask_vehicle_info:           0;
        articulated_part:               switch_mtr_wagon_articulated_part;
        running_cost_factor:            switch_mtrain_running() * runningcostfactor() + accostfactor();
    }
}

// End M-TRAIN TRAIN